    {
      "title": "Request Rate — Prefill vs Decode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(proxy_prefill_requests_total[5m])) by (prefill_instance, model)",
          "legendFormat": "prefill {{prefill_instance}} {{model}}"
        },
        {
          "expr": "sum(rate(proxy_decode_requests_total[5m])) by (decode_instance, model)",
          "legendFormat": "decode {{decode_instance}} {{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
